{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "snowflakes",
  "version": "0.1.0",
  "identifier": "com.snowflakes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "snowflakes",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/Snowflakes.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/Snowflakes.ico"
    ]
  }
}